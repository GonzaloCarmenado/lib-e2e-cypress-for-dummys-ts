{
  "name": "lib-e2e-cypress-for-dummys-ts",
  "version": "0.9.0",
  "description": "Cypress E2E test recorder — pure TypeScript, zero Angular dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lib-e2e-cypress-runner": "dist/runner.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Gonzalo Carmenado <gonzalo.carmenado@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GonzaloCarmenado/lib-e2e-cypress-for-dummys-ts.git"
  },
  "homepage": "https://github.com/GonzaloCarmenado/lib-e2e-cypress-for-dummys-ts#readme",
  "bugs": {
    "url": "https://github.com/GonzaloCarmenado/lib-e2e-cypress-for-dummys-ts/issues"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "recorder",
    "test-generator",
    "typescript",
    "custom-element",
    "web-component"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^10.3.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^17.0.2",
    "tsup": "^8.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "sweetalert2": "^11.26.24"
  }
}
