{
  "name": "lib-e2e-cypress-for-dummys",
  "version": "0.1.0",
  "description": "Cypress E2E test recorder — pure TypeScript, zero Angular dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "~5.7.2",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "sweetalert2": "^11.26.24"
  }
}
